---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CalmGridPulse from '../components/CalmGridPulse.astro';

// Direct contact only — no form/backend.
const WHATSAPP =
  'https://wa.me/923338833377?text=Hi%2C%20I%27m%20interested%20in%20a%20trade%20inquiry%20with%20BizVault.%20Please%20guide%20me%20with%20the%20process.';
const PHONE = 'tel:+923338833377';
const PHONE_DISPLAY = '+92 333 8833377';
const EMAIL = 'mailto:info@bizvault.ae';
const EMAIL_DISPLAY = 'info@bizvault.ae';
---

<Layout
  title="Contact"
  description="Share your project scope and sourcing requirements. Our team structures a tailored execution approach for every engagement."
>
  <CalmGridPulse />

  <!-- HERO -->
  <Hero
    eyebrow="Contact"
    subhead="Share your project scope and sourcing requirements. Our team structures a tailored execution approach for every engagement."
    reveal={true}
  >
    <Fragment slot="headline">Start a Trade Inquiry<span class="text-bizvault-amber">.</span></Fragment>
  </Hero>

  <!-- CONTACT METHODS — direct contact only (no form) -->
  <section class="pb-24 lg:pb-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- LEFT — intro + info + reassurance -->
        <div>
          <p class="text-xs tracking-widest uppercase text-bizvault-amber" data-reveal>Get in Touch</p>
          <h2 class="mt-4 font-display font-bold text-2xl lg:text-3xl" data-reveal data-reveal-delay="0.05">
            Reach the BizVault desk.
          </h2>

          <dl class="mt-10 space-y-8" data-reveal data-reveal-delay="0.1">
            <div class="flex items-start gap-4">
              <svg class="w-5 h-5 mt-1 text-bizvault-amber shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z" />
              </svg>
              <div>
                <dt class="text-xs uppercase tracking-widest text-bizvault-amber">Headquarters</dt>
                <dd class="mt-2 text-bizvault-text">Dubai, UAE</dd>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <svg class="w-5 h-5 mt-1 text-bizvault-amber shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 110-16 8 8 0 010 16zm.5-13h-1v6l5 3 .5-.86-4.5-2.64V7z" />
              </svg>
              <div>
                <dt class="text-xs uppercase tracking-widest text-bizvault-amber">Trade Reach</dt>
                <dd class="mt-2 text-bizvault-text">Global Corridors</dd>
              </div>
            </div>
          </dl>

          <p class="mt-10 text-bizvault-muted max-w-md leading-relaxed" data-reveal data-reveal-delay="0.15">
            Every inquiry is reviewed for scope, sourcing requirements, and regional considerations
            before we respond with a structured approach.
          </p>
        </div>

        <!-- RIGHT — direct contact methods (each card is the link) -->
        <div class="space-y-4">
          <!-- WhatsApp -->
          <a
            href={WHATSAPP}
            target="_blank"
            rel="noopener"
            data-reveal
            class="contact-card group flex items-center gap-5 bg-bizvault-surface border border-bizvault-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-bizvault-amber"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-green-500/10 text-green-400">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.06 2.87 1.21 3.07.15.2 2.09 3.2 5.07 4.49.71.31 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.13-.27-.2-.57-.35zM12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.86 9.86 0 004.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0012.04 2zm0 18.08h-.01a8.2 8.2 0 01-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 01-1.26-4.39c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 012.41 5.82c0 4.54-3.69 8.24-8.23 8.24z" />
              </svg>
            </span>
            <span class="flex-1 min-w-0">
              <span class="block text-xs uppercase tracking-widest text-bizvault-muted">WhatsApp</span>
              <span class="block mt-1 font-display font-bold text-lg text-white truncate">{PHONE_DISPLAY}</span>
            </span>
            <svg class="w-5 h-5 shrink-0 text-bizvault-muted transition-all duration-300 group-hover:text-bizvault-amber group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
          </a>

          <!-- Call -->
          <a
            href={PHONE}
            data-reveal
            data-reveal-delay="0.06"
            class="contact-card group flex items-center gap-5 bg-bizvault-surface border border-bizvault-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-bizvault-amber"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-bizvault-amber/10 text-bizvault-amber">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.02-.24 11.36 11.36 0 003.56.57 1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.24.2 2.45.57 3.57a1 1 0 01-.25 1.02l-2.2 2.2z" />
              </svg>
            </span>
            <span class="flex-1 min-w-0">
              <span class="block text-xs uppercase tracking-widest text-bizvault-muted">Call</span>
              <span class="block mt-1 font-display font-bold text-lg text-white truncate">{PHONE_DISPLAY}</span>
            </span>
            <svg class="w-5 h-5 shrink-0 text-bizvault-muted transition-all duration-300 group-hover:text-bizvault-amber group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
          </a>

          <!-- Email -->
          <a
            href={EMAIL}
            data-reveal
            data-reveal-delay="0.12"
            class="contact-card group flex items-center gap-5 bg-bizvault-surface border border-bizvault-border rounded-lg p-6 transition-all duration-300 hover:-translate-y-1 hover:border-bizvault-amber"
          >
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-bizvault-amber/10 text-bizvault-amber">
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
              </svg>
            </span>
            <span class="flex-1 min-w-0">
              <span class="block text-xs uppercase tracking-widest text-bizvault-muted">Email</span>
              <span class="block mt-1 font-display font-bold text-lg text-white truncate">{EMAIL_DISPLAY}</span>
            </span>
            <svg class="w-5 h-5 shrink-0 text-bizvault-muted transition-all duration-300 group-hover:text-bizvault-amber group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
          </a>
        </div>

      </div>
    </div>
  </section>
</Layout>
