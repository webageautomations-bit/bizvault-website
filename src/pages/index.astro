---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import DriftingNetwork from '../components/DriftingNetwork.astro';

// SSR fallback rows for the live feed (no-JS); JS takes over on load.
const feedEntries = [
  { time: 'just now', route: 'Dubai ↔ South Asia', desc: 'Industrial equipment sourcing', category: 'Equipment' },
  { time: '42s ago', route: 'Dubai ↔ Far East', desc: 'Mega project procurement support', category: 'Infrastructure' },
  { time: '1m ago', route: 'Dubai ↔ UK', desc: 'Fabric & textile trade corridor', category: 'Textiles' },
  { time: '2m ago', route: 'Dubai ↔ East Africa', desc: 'Utility infrastructure machinery', category: 'Infrastructure' },
  { time: '2m ago', route: 'Dubai ↔ Pakistan', desc: 'Textile sourcing & export coordination', category: 'Textiles' },
  { time: '3m ago', route: 'Dubai ↔ Europe', desc: 'Equipment freight & customs clearance', category: 'Equipment' },
  { time: '4m ago', route: 'Dubai ↔ MENA', desc: 'Multi-country supplier sourcing', category: 'Sourcing' },
  { time: '5m ago', route: 'Dubai ↔ South Asia', desc: 'Bottling plant equipment supply', category: 'Infrastructure' },
];

const categoryPill: Record<string, string> = {
  Equipment: 'bg-bizvault-amber/10 text-bizvault-amber',
  Infrastructure: 'bg-sky-400/10 text-sky-300',
  Textiles: 'bg-bizvault-amber-deep/15 text-bizvault-amber-deep',
  Sourcing: 'bg-teal-400/10 text-teal-300',
};

const filterTabs = ['All', 'Equipment', 'Infrastructure', 'Textiles', 'Sourcing'];

const stats = [
  { value: 'Dubai', label: 'Headquarters — UAE', count: null },
  { value: '5', label: 'Trade Verticals — Sectors', count: 5 },
  { value: '6', label: 'Group Companies — Operating', count: 6 },
  { value: 'Global', label: 'Trade Reach — Corridors', count: null },
];

// Trade lifecycle pipeline (End-to-End section)
const lifecycle = [
  { label: 'Sourcing', detail: 'Supplier identification & vetting', icon: '<circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/>' },
  { label: 'Procurement', detail: 'Purchase structuring & contracts', icon: '<path d="M21 8l-9-4.5L3 8l9 4.5 9-4.5z"/><path d="M3 8v8l9 4.5 9-4.5V8"/><path d="M12 12.5V21"/>' },
  { label: 'Logistics', detail: 'Freight, carriers & shipment', icon: '<rect x="1" y="6" width="13" height="10" rx="1"/><path d="M14 9h4l3 3v4h-7z"/><circle cx="5" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/>' },
  { label: 'Compliance', detail: 'Customs & documentation', icon: '<path d="M12 3l8 4v5c0 5-3.4 8.2-8 9-4.6-.8-8-4-8-9V7z"/><path d="M9 12l2 2 4-4"/>' },
  { label: 'Delivery', detail: 'Last-mile to project site', icon: '<path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="2.5"/>' },
];

const verticals = [
  { num: '01', title: 'Industrial & Commercial Equipment', desc: 'Sourcing, procurement, and delivery of heavy industrial and commercial machinery across international markets.' },
  { num: '02', title: 'Mega Infrastructure Movements', desc: 'End-to-end facilitation of large-scale infrastructure trade — civil, mechanical, and utility project supply chains.' },
  { num: '03', title: 'Bottling Plants', desc: 'Turnkey supply and coordination of bottling plant equipment — sourcing, documentation, and installation support.' },
  { num: '04', title: 'Water Parks & Utility Projects', desc: 'Specialised procurement and trade support for water park infrastructure and large-scale utility development projects.' },
  { num: '05', title: 'Specialised Project Trade', desc: 'Bespoke trade facilitation for complex, multi-country sourcing requirements across industrial and commercial sectors.' },
];

const verticalIcons: Record<string, string> = {
  '01': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
  '02': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M3 21h18"/><path d="M5 21V7l8-4v18"/><path d="M19 21V11l-6-4"/><path d="M9 9h.01M9 12h.01M9 15h.01M9 18h.01"/></svg>',
  '03': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M9 3h6"/><path d="M10 3v6l-5.5 9.5A2 2 0 0 0 6.2 21h11.6a2 2 0 0 0 1.7-2.5L14 9V3"/><path d="M7 15h10"/></svg>',
  '04': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M12 2.6s6.5 6.9 6.5 11.4a6.5 6.5 0 0 1-13 0C5.5 9.5 12 2.6 12 2.6z"/></svg>',
  '05': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
};

const execution = [
  { num: '01', title: 'Complexity Handled', desc: 'Multi-country procurement, parallel supplier streams, regulatory compliance — managed as a single coordinated operation.', tags: ['Multi-Country', 'Compliance', 'Procurement'] },
  { num: '02', title: 'Logistics Controlled', desc: 'From port to project site — freight coordination, customs clearance, and last-mile delivery managed end-to-end.', tags: ['Freight', 'Customs', 'Last-Mile'] },
  { num: '03', title: 'Commitments Delivered', desc: 'Every engagement built on structured processes, documented obligations, and consistent follow-through — without exception.', tags: ['Accountability', 'Structure', 'Delivery'] },
];

// Pulse/line colour per category for the radial map
const corridorColor: Record<string, string> = {
  Equipment: '#F2A93B',
  Textiles: '#C9821F',
  Sourcing: '#2dd4bf',
  Infrastructure: '#38bdf8',
};

// Region nodes positioned on a 400×400 viewBox (hub at 200,200)
const corridors = [
  { region: 'Europe', category: 'Equipment', slug: 'europe', x: 312, y: 96 },
  { region: 'Pakistan', category: 'Textiles', slug: 'pakistan', x: 206, y: 356 },
  { region: 'Far East', category: 'Sourcing', slug: 'far-east', x: 356, y: 206 },
  { region: 'UK', category: 'Textiles', slug: 'uk', x: 92, y: 92 },
  { region: 'South Asia', category: 'Equipment', slug: 'south-asia', x: 316, y: 312 },
  { region: 'East Africa', category: 'Infrastructure', slug: 'east-africa', x: 60, y: 268 },
];

const faqs = [
  { num: '01', q: 'What does BizVault specialise in?', a: 'BizVault is a Dubai-based trading company managing complex import, export, and large-scale project movements across international markets. We operate across industrial, infrastructure, and specialised commercial trade verticals.' },
  { num: '02', q: 'Which industries does BizVault operate in?', a: 'We work across multiple sectors including industrial and commercial equipment, infrastructure supply chains, bottling plant systems, water park and utility developments, and specialised multi-country project trade.' },
  { num: '03', q: 'Does BizVault execute projects directly?', a: 'BizVault facilitates and manages trade execution, procurement coordination, logistics oversight, and cross-border compliance. Our role ensures structured movement, documentation accuracy, and controlled delivery across regions.' },
  { num: '04', q: 'What regions does BizVault trade with?', a: 'Headquartered in Dubai, BizVault operates across international trade corridors, coordinating sourcing and supply across Asia, the Middle East, Europe, and other global markets as required by project scope.' },
  { num: '05', q: 'How can strategic partners or clients engage with BizVault?', a: 'Engagement begins through a formal trade enquiry. Our team reviews project scope, sourcing requirements, and regional considerations before structuring a tailored execution approach.' },
];
---

<Layout title="Home" description="BizVault FZE — Dubai-based international trading and project facilitation. Procurement, logistics, and cross-border compliance for industrial and infrastructure projects worldwide.">

  <DriftingNetwork />

  <!-- ============ HERO ============ -->
  <Hero
    eyebrow="Headquartered in Dubai, UAE"
    eyebrowDot={true}
    uppercase={true}
    tall={true}
    subhead="BizVault FZE is a Dubai-based international trading and project facilitation company — managing procurement, logistics, and compliance for industrial and infrastructure projects across global markets."
  >
    <Fragment slot="headline">
      <span class="block">Where</span>
      <span class="block text-bizvault-amber">Large-Scale</span>
      <span class="block">Trade Gets Done.</span>
    </Fragment>

    <Fragment slot="cta">
      <a
        href="/contact"
        class="bg-bizvault-amber text-bizvault-bg px-6 py-3 rounded-md text-xs font-semibold tracking-widest uppercase hover:bg-amber-400 transition"
      >
        Submit a Trade Inquiry
      </a>
      <a
        href="#feed"
        class="border border-bizvault-border text-bizvault-text px-6 py-3 rounded-md text-xs font-semibold tracking-widest uppercase hover:border-bizvault-amber transition"
      >
        Scroll to Explore
      </a>
    </Fragment>

    <!-- Right: Trade Feed -->
    <div id="feed" slot="right" class="relative bg-bizvault-surface border border-bizvault-border rounded-lg overflow-hidden">

        <!-- Scanline shimmer (decorative, radar-style refresh) -->
        <div class="feed-scanline" aria-hidden="true"></div>

        <!-- Header row -->
        <div class="p-4 border-b border-bizvault-border flex justify-between items-center">
          <span class="text-sm font-medium">BizVault Trade Feed</span>
          <span class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-bizvault-amber animate-pulse"></span>
            <span class="text-bizvault-muted text-xs uppercase tracking-widest">Live</span>
          </span>
        </div>

        <!-- Live metrics -->
        <div class="px-4 py-2.5 border-b border-bizvault-border flex flex-wrap items-center gap-x-4 gap-y-1 text-[11px]">
          <span class="flex items-center gap-1.5 text-bizvault-muted">
            <span class="w-1.5 h-1.5 rounded-full bg-bizvault-amber animate-pulse"></span>
            <span id="feed-count" class="text-bizvault-text font-medium tabular-nums">1,247</span> active movements
          </span>
          <span class="text-bizvault-muted">6 corridors online</span>
          <span class="text-bizvault-muted ml-auto">updated <span id="feed-updated" class="text-bizvault-text">just now</span></span>
        </div>

        <!-- Filter tabs -->
        <div class="flex gap-5 px-4 py-3 border-b border-bizvault-border overflow-x-auto">
          {filterTabs.map((tab) => (
            <button
              type="button"
              data-filter={tab}
              class={`feed-tab whitespace-nowrap text-xs font-medium tracking-widest uppercase py-2.5 lg:py-1 lg:pb-1 border-b-2 transition ${
                tab === 'All'
                  ? 'text-white border-bizvault-amber'
                  : 'text-bizvault-muted border-transparent'
              }`}
            >
              {tab}
            </button>
          ))}
        </div>

        <!-- Fixed-height scrollable list -->
        <div class="h-[420px] overflow-y-auto divide-y divide-bizvault-border" id="feed-list">
          {feedEntries.map((entry) => (
            <div class="feed-row flex items-center gap-3 p-4" data-category={entry.category}>
              <span class="feed-time text-bizvault-muted text-xs tabular-nums shrink-0 w-16">{entry.time}</span>
              <div class="feed-reveal min-w-0 flex-1">
                <p class="text-sm font-medium truncate">{entry.route}</p>
                <p class="text-bizvault-muted text-xs mt-0.5">{entry.desc}</p>
              </div>
              <span class={`feed-pill shrink-0 text-[10px] uppercase tracking-widest px-2 py-1 rounded ${categoryPill[entry.category]}`}>
                {entry.category}
              </span>
            </div>
          ))}
        </div>

        <!-- Fine print (pinned below the fixed list) -->
        <div class="p-4 text-bizvault-muted text-xs border-t border-bizvault-border">
          Trade entries shown are illustrative. Routes and verticals reflect BizVault's actual operational scope.
        </div>

      </div>
  </Hero>

  <!-- ============ STATS STRIP ============ -->
  <section id="stats-strip" class="border-y border-bizvault-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 md:divide-x divide-bizvault-amber/15">
        {stats.map((stat) => (
          <div class="stat-cell group relative py-10 px-4 md:px-8 text-center md:text-left transition-all duration-300 hover:bg-[#15151a] hover:shadow-[0_0_40px_-12px_rgba(242,169,59,0.30)]">
            <span class="block h-0.5 w-8 rounded-full bg-bizvault-amber/80 mb-4 mx-auto md:mx-0 transition-all duration-300 group-hover:w-12 group-hover:bg-bizvault-amber"></span>
            <p class="font-display text-3xl lg:text-4xl leading-none">
              {stat.count != null
                ? <span class="stat-num text-bizvault-amber">{stat.count}</span>
                : <span class="stat-text inline-block text-white border-b-2 border-bizvault-amber/50 pb-1 transition-colors duration-300 group-hover:border-bizvault-amber">{stat.value}</span>}
            </p>
            <p class="text-xs tracking-widest uppercase text-bizvault-muted mt-3">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ END-TO-END ============ -->
  <section id="end-to-end" class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Left sticky headline + drawing accent line -->
      <div class="lg:col-span-2">
        <div class="lg:sticky lg:top-28">
          <h2 class="font-display font-black tracking-tight text-4xl lg:text-5xl leading-[1.05]">
            End-to-End Trade &amp; Project Execution<span class="text-bizvault-amber">.</span>
          </h2>
          <div class="mt-8 h-32 w-px bg-bizvault-border relative overflow-hidden">
            <span data-e2e-line class="absolute inset-0 origin-top scale-y-0 bg-gradient-to-b from-bizvault-amber to-bizvault-amber/0"></span>
          </div>
        </div>
      </div>
      <!-- Right paragraphs -->
      <div class="lg:col-span-3 space-y-8">
        <p class="text-bizvault-text/80 text-lg leading-relaxed">
          BizVault FZE manages the full <span class="ul-draw">lifecycle of international trade</span> — from supplier sourcing and procurement through to logistics, compliance, and final delivery. We operate across industrial, infrastructure, and commercial sectors, facilitating large-scale movements that require structure, reliability, and execution discipline.
        </p>
        <p class="text-bizvault-text/80 text-lg leading-relaxed">
          Where others stop at supply, <span class="ul-draw">BizVault goes further</span> — coordinating across borders, jurisdictions, and project timelines to ensure every engagement lands as committed.
        </p>
      </div>
    </div>

    <!-- Lifecycle: scroll-driven traveling-shipment pipeline -->
    <div id="lifecycle" class="mt-20 lg:mt-28">
      <p data-reveal class="text-xs tracking-widest uppercase text-bizvault-muted mb-10">The Trade Lifecycle</p>

      <!-- Desktop horizontal track -->
      <div class="lc-track relative hidden md:block h-[150px]">
        <!-- base + fill lines (span node 1 → node 5 centres, 10%→90%) -->
        <div class="absolute left-[10%] right-[10%] top-6 h-0.5 -translate-y-1/2 bg-bizvault-border z-0"></div>
        <div data-lc-fill class="absolute left-[10%] top-6 h-0.5 w-[80%] -translate-y-1/2 origin-left scale-x-0 bg-bizvault-amber z-0"></div>

        <!-- traveling shipment -->
        <div data-lc-ship class="lc-ship absolute top-6 left-[10%] -translate-x-1/2 -translate-y-1/2 z-20 pointer-events-none">
          <span class="lc-ship-inner relative flex h-7 w-9 items-center justify-center rounded-md bg-bizvault-amber text-bizvault-bg shadow-[0_0_16px_rgba(242,169,59,0.7)]">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/></svg>
          </span>
        </div>

        {lifecycle.map((s, i) => (
          <div class="lc-node group absolute top-0 -translate-x-1/2 z-10 flex flex-col items-center text-center cursor-pointer" style={`left:${10 + i * 20}%`} data-lc-node data-index={i}>
            <span class="lc-dot relative flex h-12 w-12 items-center justify-center rounded-full border border-bizvault-border bg-bizvault-bg text-bizvault-muted transition-all duration-300">
              <span class="lc-glow pointer-events-none absolute -inset-1 rounded-full bg-bizvault-amber/30 blur-md opacity-0 transition-opacity duration-300"></span>
              <svg class="relative w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
            </span>
            <span class="lc-label mt-4 font-display text-sm text-bizvault-muted transition-colors duration-300">{s.label}</span>
            <span class="lc-detail mt-1 text-xs text-bizvault-muted opacity-0 translate-y-1 transition-all duration-300 max-w-[10rem]">{s.detail}</span>
          </div>
        ))}
      </div>

      <!-- Mobile vertical track -->
      <div class="lc-track-v relative md:hidden">
        <div class="absolute left-6 top-6 bottom-6 w-0.5 -translate-x-1/2 bg-bizvault-border z-0"></div>
        <div data-lc-fill-v class="absolute left-6 top-6 w-0.5 -translate-x-1/2 origin-top scale-y-0 bg-bizvault-amber z-0" style="height:calc(100% - 3rem)"></div>
        <div data-lc-ship-v class="lc-ship absolute left-6 top-6 -translate-x-1/2 -translate-y-1/2 z-20 pointer-events-none">
          <span class="lc-ship-inner relative flex h-7 w-9 items-center justify-center rounded-md bg-bizvault-amber text-bizvault-bg shadow-[0_0_16px_rgba(242,169,59,0.7)]">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7l9-4 9 4-9 4-9-4z"/><path d="M3 7v10l9 4 9-4V7"/></svg>
          </span>
        </div>
        <div class="flex flex-col gap-9">
          {lifecycle.map((s, i) => (
            <div class="lc-node group relative flex items-center gap-4 cursor-pointer z-10" data-lc-node data-index={i}>
              <span class="lc-dot relative flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-bizvault-border bg-bizvault-bg text-bizvault-muted transition-all duration-300">
                <span class="lc-glow pointer-events-none absolute -inset-1 rounded-full bg-bizvault-amber/30 blur-md opacity-0 transition-opacity duration-300"></span>
                <svg class="relative w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon}></svg>
              </span>
              <div>
                <span class="lc-label block font-display text-sm text-bizvault-muted transition-colors duration-300">{s.label}</span>
                <span class="lc-detail block text-xs text-bizvault-muted opacity-0 -translate-y-1 transition-all duration-300">{s.detail}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRADE VERTICALS ============ -->
  <section id="verticals" class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
    <p class="text-xs tracking-widest uppercase text-bizvault-amber">Trade Verticals</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-10 items-stretch">
      {verticals.map((v) => (
        <div class="vert-card group relative flex flex-col h-full overflow-hidden bg-bizvault-surface border border-bizvault-border rounded-lg p-6 lg:p-8 transition-all duration-[250ms] ease-out hover:-translate-y-1 hover:border-bizvault-amber">
          <span class="pointer-events-none absolute -top-16 -right-16 w-32 h-32 rounded-full bg-bizvault-amber/0 blur-2xl transition-colors duration-300 group-hover:bg-bizvault-amber/20"></span>
          <div class="relative flex items-center justify-between">
            <span class="text-bizvault-amber transition-colors duration-300 group-hover:text-amber-300" set:html={verticalIcons[v.num]} />
            <span class="font-display text-bizvault-amber text-sm">{v.num}</span>
          </div>
          <h3 class="relative font-display font-bold text-lg text-white mt-4">{v.title}</h3>
          <p class="relative text-bizvault-muted text-sm leading-relaxed mt-3">{v.desc}</p>
        </div>
      ))}

      <!-- CTA card completes the 3×2 grid -->
      <a
        href="/services"
        class="vert-card group relative flex flex-col justify-center h-full overflow-hidden rounded-lg p-6 lg:p-8 bg-bizvault-amber/10 border border-bizvault-amber/40 transition-all duration-[250ms] ease-out hover:-translate-y-1 hover:border-bizvault-amber hover:bg-bizvault-amber/[0.16]"
      >
        <span class="font-display font-bold text-xl lg:text-2xl text-white leading-tight">Explore Full<br />Capabilities</span>
        <span class="mt-4 inline-flex items-center gap-2 text-bizvault-amber text-xs font-semibold tracking-widest uppercase">
          View Services
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </span>
      </a>
    </div>
  </section>

  <!-- ============ HOW BIZVAULT EXECUTES ============ -->
  <section class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32 overflow-hidden">
    <p data-reveal class="text-xs tracking-widest uppercase text-bizvault-amber">How BizVault Executes</p>
    <div class="mt-14 space-y-16 lg:space-y-24">
      {execution.map((e, i) => (
        <div class={`exec-row group relative max-w-3xl ${i % 2 === 1 ? 'lg:ml-auto' : 'mr-auto'}`}>
          <span class="exec-ghost pointer-events-none absolute -top-10 -left-2 lg:-left-6 font-display font-black leading-none text-[7rem] lg:text-[12rem] text-white/[0.05] transition-colors duration-300 select-none">{e.num}</span>
          <div class="relative pl-6">
            <span class="exec-line absolute left-0 top-1 h-[calc(100%-0.5rem)] w-0.5 origin-top scale-y-0 bg-bizvault-amber"></span>
            <h3 data-exec-item class="font-display font-bold text-2xl lg:text-4xl text-white">{e.title}</h3>
