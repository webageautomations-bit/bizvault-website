  .lc-node.is-hover .lc-dot { transform: scale(1.12); border-color: #f2a93b; }
  .lc-node.is-hover .lc-glow { opacity: 1; }
  .lc-node.is-hover .lc-label { color: #fafafa; }
  .lc-node.is-hover .lc-detail { opacity: 1; transform: translateY(0); }
  /* arrival pop + customs stamp flash */
