      <div class="lg:col-span-3">
        {faqs.map((item, i) => (
          <div data-reveal data-reveal-delay={(i * 0.06).toFixed(2)} class={`faq-item relative border-b border-bizvault-border ${i === 0 ? 'is-open' : ''}`}>
            <span class="faq-sweep absolute -bottom-px left-0 h-px w-0 bg-bizvault-amber transition-all duration-300"></span>
            <button type="button" class="faq-q w-full text-left cursor-pointer py-5 flex justify-between items-center gap-4">
