  .lc-node.lc-pop .lc-dot { animation: lcPop 0.5s ease; }
  @keyframes lcStamp { 0% { box-shadow: 0 0 0 0 rgba(242, 169, 59, 0.5); } 100% { box-shadow: 0 0 0 14px rgba(242, 169, 59, 0); } }
