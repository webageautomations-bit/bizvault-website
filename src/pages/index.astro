<!-- Live Trade Feed + FAQ accordion (DOM-only, no imports) -->
<script>
  type Entry = { route: string; desc: string; category: string };
  type LiveEntry = Entry & { ts: number };

  /* ===== Live Trade Feed ===== */
  const list = document.getElementById('feed-list');
  if (list) {
    const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const MAX = 8;

    const pill: Record<string, string> = {
      Equipment: 'bg-bizvault-amber/10 text-bizvault-amber',
      Infrastructure: 'bg-sky-400/10 text-sky-300',
      Textiles: 'bg-bizvault-amber-deep/15 text-bizvault-amber-deep',
      Sourcing: 'bg-teal-400/10 text-teal-300',
    };

    const pool: Entry[] = [
      { route: 'Dubai ↔ South Asia', desc: 'Industrial equipment sourcing', category: 'Equipment' },
      { route: 'Dubai ↔ Far East', desc: 'Mega project procurement support', category: 'Infrastructure' },
      { route: 'Dubai ↔ UK', desc: 'Fabric & textile trade corridor', category: 'Textiles' },
      { route: 'Dubai ↔ East Africa', desc: 'Utility infrastructure machinery', category: 'Infrastructure' },
      { route: 'Dubai ↔ Pakistan', desc: 'Textile sourcing & export coordination', category: 'Textiles' },
      { route: 'Dubai ↔ Europe', desc: 'Equipment freight & customs clearance', category: 'Equipment' },
      { route: 'Dubai ↔ MENA', desc: 'Multi-country supplier sourcing', category: 'Sourcing' },
      { route: 'Dubai ↔ South Asia', desc: 'Bottling plant equipment supply', category: 'Infrastructure' },
      { route: 'Dubai ↔ Central Asia', desc: 'Heavy machinery procurement stream', category: 'Equipment' },
      { route: 'Dubai ↔ Southeast Asia', desc: 'Multi-supplier sourcing coordination', category: 'Sourcing' },
      { route: 'Dubai ↔ China', desc: 'Component sourcing & consolidation', category: 'Sourcing' },
      { route: 'Dubai ↔ Turkey', desc: 'Textile mill export coordination', category: 'Textiles' },
      { route: 'Dubai ↔ India', desc: 'Industrial valve & pump procurement', category: 'Equipment' },
      { route: 'Dubai ↔ GCC', desc: 'Water park equipment supply', category: 'Infrastructure' },
      { route: 'Dubai ↔ Bangladesh', desc: 'Garment export logistics coordination', category: 'Textiles' },
      { route: 'Dubai ↔ West Africa', desc: 'Project cargo & freight planning', category: 'Infrastructure' },
    ];

    let active = 'All';
    let feed: LiveEntry[] = [];
    let lastInsert = Date.now();

    const relTime = (ts: number, now: number): string => {
      const s = Math.max(0, Math.round((now - ts) / 1000));
      if (s < 5) return 'just now';
      if (s < 60) return `${s}s ago`;
      const m = Math.floor(s / 60);
      if (m < 60) return `${m}m ago`;
      return `${Math.floor(m / 60)}h ago`;
    };

    const esc = (v: string) => v.replace(/&/g, '&amp;').replace(/</g, '&lt;');

    const rowHTML = (e: LiveEntry, now: number): string =>
      `<div class="feed-row flex items-center gap-3 p-4" data-category="${e.category}" data-ts="${e.ts}">` +
      `<span class="feed-time text-bizvault-muted text-xs tabular-nums shrink-0 w-16">${relTime(e.ts, now)}</span>` +
      `<div class="feed-reveal min-w-0 flex-1"><p class="text-sm font-medium truncate">${esc(e.route)}</p>` +
      `<p class="text-bizvault-muted text-xs mt-0.5">${esc(e.desc)}</p></div>` +
      `<span class="feed-pill shrink-0 text-[10px] uppercase tracking-widest px-2 py-1 rounded ${pill[e.category] || ''}">${e.category}</span>` +
      `</div>`;

    const renderList = (animateTop: boolean) => {
      const now = Date.now();
      const visible = feed.filter((e) => active === 'All' || e.category === active).slice(0, MAX);
      list.innerHTML = visible.map((e) => rowHTML(e, now)).join('');
      if (animateTop && !REDUCE) {
        const row = list.firstElementChild as HTMLElement | null;
        if (row) {
          row.classList.add('feed-row--enter');
          void row.offsetHeight; // flush so the animation runs
          // Status lifecycle: show "ROUTING" then settle into the category pill
          const pillEl = row.querySelector('.feed-pill') as HTMLElement | null;
          const cat = row.dataset.category || '';
          if (pillEl) {
            pillEl.className = 'feed-pill shrink-0 inline-flex items-center gap-1 text-[10px] uppercase tracking-widest px-2 py-1 rounded bg-bizvault-amber/15 text-bizvault-amber';
            pillEl.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-bizvault-amber animate-pulse"></span>Routing';
            window.setTimeout(() => {
              if (!pillEl.isConnected) return;
              pillEl.className = `feed-pill shrink-0 text-[10px] uppercase tracking-widest px-2 py-1 rounded ${pill[cat] || ''}`;
              pillEl.textContent = cat;
            }, 1500);
          }
        }
      }
    };

    const updateTimes = () => {
      const now = Date.now();
      list.querySelectorAll<HTMLElement>('.feed-row').forEach((row) => {
        const t = row.querySelector('.feed-time');
        if (t) t.textContent = relTime(Number(row.dataset.ts), now);
      });
      const upd = document.getElementById('feed-updated');
      if (upd) upd.textContent = relTime(lastInsert, now);
    };

    const pickEntry = (): Entry => {
      const choices = active === 'All' ? pool : pool.filter((p) => p.category === active);
      const src = choices.length ? choices : pool;
      return src[Math.floor(Math.random() * src.length)];
    };

    // Seed with ageing timestamps so the initial feed already looks live.
    const now0 = Date.now();
    feed = pool.slice(0, MAX).map((e, i) => ({ ...e, ts: now0 - (i + 1) * 42000 }));
    renderList(false);

    document.querySelectorAll<HTMLButtonElement>('.feed-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        active = tab.dataset.filter || 'All';
        document.querySelectorAll<HTMLButtonElement>('.feed-tab').forEach((t) => {
          const on = t === tab;
          t.classList.toggle('text-white', on);
          t.classList.toggle('border-bizvault-amber', on);
          t.classList.toggle('text-bizvault-muted', !on);
          t.classList.toggle('border-transparent', !on);
        });
        renderList(false);
      });
    });

    // Live metrics counter
    const countEl = document.getElementById('feed-count');
    let movements = 1247;
    const fmt = (n: number) => n.toLocaleString('en-US');

    if (!REDUCE) {
      setInterval(updateTimes, 1000);

      setInterval(() => {
        movements += 1 + Math.floor(Math.random() * 3);
        if (countEl) countEl.textContent = fmt(movements);
      }, 6000);

      const loop = () => {
        window.setTimeout(() => {
          feed.unshift({ ...pickEntry(), ts: Date.now() });
          if (feed.length > 40) feed.length = 40;
          lastInsert = Date.now();
          renderList(true);
          const upd = document.getElementById('feed-updated');
          if (upd) upd.textContent = 'just now';
          loop();
        }, 4000 + Math.random() * 2000);
      };
      loop();
    }
  }

  /* ===== FAQ accordion (one open at a time, smooth height) ===== */
  const faqItems = Array.from(document.querySelectorAll<HTMLElement>('.faq-item'));
  if (faqItems.length) {
    const setOpen = (item: HTMLElement, open: boolean) => {
      item.classList.toggle('is-open', open);
      const panel = item.querySelector('.faq-a') as HTMLElement | null;
      if (panel) panel.style.maxHeight = open ? `${panel.scrollHeight}px` : '0px';
    };
    faqItems.forEach((item) => {
      const btn = item.querySelector('.faq-q');
      btn?.addEventListener('click', () => {
        const wasOpen = item.classList.contains('is-open');
        faqItems.forEach((i) => setOpen(i, false));
        if (!wasOpen) setOpen(item, true);
      });
    });
    // First item open by default
    setOpen(faqItems[0], true);
    window.addEventListener('resize', () => {
      const openPanel = document.querySelector('.faq-item.is-open .faq-a') as HTMLElement | null;
      if (openPanel) openPanel.style.maxHeight = `${openPanel.scrollHeight}px`;
    });
  }
</script>

<!-- Scroll animations (GSAP/ScrollTrigger configured globally in Layout) -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  /* ===== Stats strip — bulletproof reveal + count-up ===== */
  const strip = document.getElementById('stats-strip');
  if (strip) {
    const cells = gsap.utils.toArray<HTMLElement>('.stat-cell');
    const nums = Array.from(strip.querySelectorAll<HTMLElement>('.stat-num'));
    const targets = new Map<HTMLElement, number>();
    nums.forEach((n) => targets.set(n, Number((n.textContent || '0').trim())));

    if (reduce) {
      // Final, fully visible state — numbers already show their value in the HTML.
      gsap.set(cells, { opacity: 1, y: 0 });
    } else {
      gsap.set(cells, { opacity: 0, y: 24 });
      nums.forEach((n) => { n.textContent = '0'; });

      let revealed = false;
      const reveal = () => {
        if (revealed) return;
        revealed = true;
        gsap.to(cells, {
          opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: 'power2.out', overwrite: 'auto',
          onComplete: () => gsap.set(cells, { clearProps: 'opacity,transform' }),
        });
        nums.forEach((n) => {
          const target = targets.get(n) || 0;
          const obj = { v: 0 };
          gsap.to(obj, {
            v: target, duration: 1.2, ease: 'power2.out',
            onUpdate: () => { n.textContent = String(Math.round(obj.v)); },
            onComplete: () => { n.textContent = String(target); },
          });
        });
      };

      // Primary trigger.
      ScrollTrigger.create({ trigger: strip, start: 'top 85%', once: true, onEnter: reveal });
      // Bulletproof fallback: IntersectionObserver guarantees the reveal whether the
      // strip is already in view on load OR scrolled into view later (covers Lenis/refresh
      // timing edge-cases that can otherwise leave cells stuck hidden).
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { reveal(); io.disconnect(); } });
      }, { threshold: 0.15 });
      io.observe(strip);
    }
  }

  /* ===== Trade Verticals stagger ===== */
  const vertSection = document.getElementById('verticals');
  if (vertSection && !reduce) {
    const cards = gsap.utils.toArray<HTMLElement>('#verticals .vert-card');
    gsap.set(cards, { opacity: 0, y: 30 });
    ScrollTrigger.create({
      trigger: vertSection, start: 'top 80%', once: true,
      onEnter: () => gsap.to(cards, { opacity: 1, y: 0, duration: 0.7, stagger: 0.1, ease: 'power2.out' }),
    });
  }

  /* ===== End-to-End: accent line scrub + underline draw + lifecycle shipment ===== */
  const e2e = document.getElementById('end-to-end');
  if (e2e) {
    const vline = e2e.querySelector<HTMLElement>('[data-e2e-line]');
    const uls = Array.from(e2e.querySelectorAll<HTMLElement>('.ul-draw'));
    const lifecycleEl = document.getElementById('lifecycle');
    const lcNodes = Array.from(e2e.querySelectorAll<HTMLElement>('[data-lc-node]'));
    const fillH = e2e.querySelector<HTMLElement>('[data-lc-fill]');
    const fillV = e2e.querySelector<HTMLElement>('[data-lc-fill-v]');
    const shipH = e2e.querySelector<HTMLElement>('[data-lc-ship]');
    const shipV = e2e.querySelector<HTMLElement>('[data-lc-ship-v]');
    const trackV = e2e.querySelector<HTMLElement>('.lc-track-v');

    // Position the shipment + grow the fill line for a given progress 0→1.
    const positionShip = (p: number) => {
      if (fillH) fillH.style.transform = `scaleX(${p})`;
      if (fillV) fillV.style.transform = `scaleY(${p})`;
      if (shipH) shipH.style.left = `${10 + p * 80}%`;
      if (shipV && trackV) shipV.style.top = `${24 + p * (trackV.clientHeight - 48)}px`;
    };
    const setNodes = (p: number) => {
      lcNodes.forEach((n) => n.classList.toggle('is-on', p >= Number(n.dataset.index) / 4 - 0.001));
    };

    // Hover (desktop) / tap (mobile) spotlight — independent of scroll position.
    lcNodes.forEach((node) => {
      const track = node.closest('.lc-track, .lc-track-v');
      node.addEventListener('mouseenter', () => { node.classList.add('is-hover'); track?.classList.add('has-hover'); });
      node.addEventListener('mouseleave', () => { node.classList.remove('is-hover'); track?.classList.remove('has-hover'); });
      node.addEventListener('click', () => {
        const was = node.classList.contains('is-hover');
        track?.querySelectorAll('.lc-node').forEach((n) => n.classList.remove('is-hover'));
        if (!was) { node.classList.add('is-hover'); track?.classList.add('has-hover'); }
        else { track?.classList.remove('has-hover'); }
      });
    });

    if (reduce) {
      if (vline) vline.style.transform = 'scaleY(1)';
      uls.forEach((u) => u.classList.add('is-drawn'));
      positionShip(1);
      lcNodes.forEach((n) => n.classList.add('is-on'));
    } else {
      // Vertical accent line draws with scroll
      if (vline) {
        gsap.fromTo(vline, { scaleY: 0 }, {
          scaleY: 1, ease: 'none',
          scrollTrigger: { trigger: e2e, start: 'top 70%', end: 'bottom 75%', scrub: true },
        });
      }
      // Underlines draw once when the section enters
      ScrollTrigger.create({ trigger: e2e, start: 'top 65%', once: true, onEnter: () => uls.forEach((u) => u.classList.add('is-drawn')) });

      // Lifecycle shipment — scrubbed travel + arrival activation (pop / customs stamp)
      const activated = new Set<number>();
      let lastP = 0;
      const apply = (p: number) => {
        lastP = p;
        positionShip(p);
        setNodes(p);
        for (let i = 0; i < 5; i++) {
          if (p >= i / 4 - 0.001 && !activated.has(i)) {
            activated.add(i);
            e2e.querySelectorAll(`[data-lc-node][data-index="${i}"]`).forEach((n) => {
              n.classList.add(i === 3 ? 'lc-stamp' : 'lc-pop');
              window.setTimeout(() => { n.classList.remove('lc-pop'); n.classList.remove('lc-stamp'); }, 650);
            });
          } else if (p < i / 4 - 0.03 && activated.has(i)) {
            activated.delete(i);
          }
        }
      };
      apply(0);
      if (lifecycleEl) {
        ScrollTrigger.create({
          trigger: lifecycleEl, start: 'top 80%', end: 'bottom 70%', scrub: true,
          onUpdate: (self) => apply(self.progress),
        });
      }
      window.addEventListener('resize', () => positionShip(lastP));
    }
  }

  /* ===== How Executes: per-principle reveal ===== */
  const execRows = gsap.utils.toArray<HTMLElement>('.exec-row');
  execRows.forEach((row) => {
    const ghost = row.querySelector<HTMLElement>('.exec-ghost');
    const line = row.querySelector<HTMLElement>('.exec-line');
    const items = gsap.utils.toArray<HTMLElement>(row.querySelectorAll('[data-exec-item]'));
    if (reduce) {
      if (line) line.style.transform = 'scaleY(1)';
      return;
    }
    if (ghost) gsap.set(ghost, { opacity: 0, x: -20 });
    if (line) gsap.set(line, { scaleY: 0 });
    gsap.set(items, { opacity: 0, y: 24 });
    ScrollTrigger.create({
      trigger: row, start: 'top 80%', once: true,
      onEnter: () => {
        const tl = gsap.timeline();
        if (ghost) tl.to(ghost, { opacity: 1, x: 0, duration: 0.7, ease: 'power2.out' }, 0);
        if (line) tl.to(line, { scaleY: 1, duration: 0.6, ease: 'power2.out' }, 0.1);
        tl.to(items, { opacity: 1, y: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out' }, 0.15);
      },
    });
  });
  const execClose = document.querySelector<HTMLElement>('[data-exec-close]');
  if (execClose && !reduce) {
    gsap.set(execClose, { opacity: 0, y: 24 });
    ScrollTrigger.create({
      trigger: execClose, start: 'top 85%', once: true,
      onEnter: () => gsap.to(execClose, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }),
    });
  }

  /* ===== Global Reach: radial map draw + live pulses + hover highlight ===== */
  const map = document.getElementById('reach-map');
  if (map) {
    const HUB = { x: 200, y: 200 };
    const lines = Array.from(map.querySelectorAll<SVGLineElement>('.reach-line'));
    const outerNodes = Array.from(map.querySelectorAll<SVGGElement>('.reach-node'));
    const marks = Array.from(map.querySelectorAll<SVGGElement>('.reach-node-mark'));
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.reach-row'));
    const pulseLayer = map.querySelector('#reach-pulses');

    // Prepare line draw
    lines.forEach((l) => {
      const len = l.getTotalLength();
      l.style.strokeDasharray = `${len}`;
      l.style.strokeDashoffset = reduce ? '0' : `${len}`;
    });

    // Build pulse dots — travel hub-centre → node-centre (same x2/y2 as the line)
    const pulses = lines.map((l) => {
      const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      c.setAttribute('r', '3');
      c.setAttribute('fill', l.dataset.color || '#F2A93B');
      c.setAttribute('opacity', '0');
      pulseLayer?.appendChild(c);
      return { el: c, x2: Number(l.getAttribute('x2')), y2: Number(l.getAttribute('y2')) };
    });

    let pulsesOn = false;
    const animatePulses = (t: number) => {
      pulses.forEach((p, i) => {
        const phase = ((t / 2600) + i / pulses.length) % 1;
        p.el.setAttribute('cx', String(HUB.x + (p.x2 - HUB.x) * phase));
        p.el.setAttribute('cy', String(HUB.y + (p.y2 - HUB.y) * phase));
        const op = phase < 0.12 ? phase / 0.12 : phase > 0.85 ? (1 - phase) / 0.15 : 1;
        p.el.setAttribute('opacity', String(0.9 * Math.max(0, op)));
      });
      requestAnimationFrame(animatePulses);
    };

    if (reduce) {
      gsap.set(marks, { opacity: 1, scale: 1 });
    } else {
      gsap.set(marks, { scale: 0, opacity: 0 });
      let revealed = false;
      const reveal = () => {
        if (revealed) return;
        revealed = true;
        const tl = gsap.timeline();
        tl.to(lines, { strokeDashoffset: 0, duration: 0.9, stagger: 0.12, ease: 'power2.out' });
        tl.to(marks, {
          scale: 1, opacity: 1, duration: 0.5, stagger: 0.1, ease: 'back.out(1.7)',
          onComplete: () => gsap.set(marks, { clearProps: 'transform,opacity' }),
        }, '-=0.5');
        tl.add(() => { if (!pulsesOn) { pulsesOn = true; requestAnimationFrame(animatePulses); } });
      };
      // Primary + IntersectionObserver fallback so the map never stays hidden.
      ScrollTrigger.create({ trigger: map, start: 'top 80%', once: true, onEnter: reveal });
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { reveal(); io.disconnect(); } });
      }, { threshold: 0.1 });
      io.observe(map);
    }

    // Reciprocal hover highlight (row ↔ its line + node) — works for all 6 corridors
    const highlight = (slug: string | null) => {
      map.classList.toggle('has-hl', !!slug);
      lines.forEach((l) => l.classList.toggle('hl', !!slug && l.id === `line-${slug}`));
      outerNodes.forEach((n) => n.classList.toggle('hl', !!slug && n.dataset.corridor === slug));
      rows.forEach((r) => r.classList.toggle('hl', !!slug && r.dataset.corridor === slug));
    };
    rows.forEach((row) => {
      row.addEventListener('mouseenter', () => highlight(row.dataset.corridor || null));
      row.addEventListener('mouseleave', () => highlight(null));
    });
    outerNodes.forEach((node) => {
      node.addEventListener('mouseenter', () => highlight(node.dataset.corridor || null));
      node.addEventListener('mouseleave', () => highlight(null));
    });
  }
</script>
