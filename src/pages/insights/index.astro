---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import CalmGridPulse from '../../components/CalmGridPulse.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categories = ['All', 'Procurement', 'Logistics', 'Compliance', 'Trade Insights', 'Industry'];

// Category colour system → drives pills, accents, gradients, glows, underlines.
const catColors: Record<string, { accent: string; deep: string; pillBg: string; pillText: string }> = {
  Procurement: { accent: '#F2A93B', deep: '#9c6610', pillBg: '#3a2c10', pillText: '#F2A93B' },
  Logistics: { accent: '#3b82d8', deep: '#1f4e8a', pillBg: '#13243a', pillText: '#5b9be0' },
  Compliance: { accent: '#3aa88f', deep: '#1f6b5a', pillBg: '#0f2e28', pillText: '#4fc7ad' },
  'Trade Insights': { accent: '#7c6ff0', deep: '#3b2f99', pillBg: '#1e1a3a', pillText: '#9a8ff5' },
  Industry: { accent: '#d8557a', deep: '#7a2440', pillBg: '#3a1622', pillText: '#e08aa3' },
};
const AMBER = '#F2A93B';

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// CSS custom-property string for a post's category palette.
const vars = (cat: string) => {
  const c = catColors[cat] || catColors.Procurement;
  return `--cat:${c.accent};--cat-deep:${c.deep};--pill-bg:${c.pillBg};--pill-text:${c.pillText}`;
};

const featured = posts[0];
---

<Layout
  title="Insights — Trade Intelligence & Insights | BizVault FZE"
  description="BizVault FZE's perspective on global trade, procurement, logistics, and compliance across international corridors."
>
  <CalmGridPulse />

  <Hero
    eyebrow="Insights"
    subhead="Field-tested perspective from the people who move goods across borders. BizVault's view on procurement, logistics, compliance, and the corridors that connect global trade."
    reveal={true}
  >
    <Fragment slot="headline">Trade Intelligence &amp; Insights<span class="text-bizvault-amber">.</span></Fragment>
  </Hero>

  <section class="max-w-7xl mx-auto px-6 lg:px-8 pb-24 lg:pb-32">

    <!-- Category filter bar -->
    <div class="flex flex-wrap gap-3" id="filter-bar">
      {
        categories.map((cat) => (
          <button
            type="button"
            data-filter={cat}
            data-accent={cat === 'All' ? AMBER : catColors[cat].accent}
            class="filter-btn px-5 py-3 lg:py-2.5 rounded-md text-xs font-semibold tracking-widest uppercase border border-bizvault-border text-bizvault-muted transition hover:text-white"
          >
            {cat}
          </button>
        ))
      }
    </div>

    <div id="blog-main">
      <!-- FEATURED SPOTLIGHT (newest post) -->
      {featured && (
        <a
          id="featured-card"
          href={`/insights/${featured.id}`}
          data-id={featured.id}
          data-category={featured.data.category}
          style={vars(featured.data.category)}
          class="featured-card group relative grid lg:grid-cols-2 mt-12 rounded-xl overflow-hidden border border-bizvault-border bg-bizvault-surface transition-[transform,border-color] duration-300"
        >
          <!-- COVER: treated photo (if present) with category tint + dark gradient; gradient fallback otherwise -->
          <div class="featured-cover relative min-h-[220px] lg:min-h-[360px] p-8 flex flex-col justify-between overflow-hidden">
            {featured.data.cover ? (
              <img
                src={featured.data.cover}
                alt=""
                width="1200"
                height="800"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <span class="absolute inset-0" style="background-image:linear-gradient(135deg, var(--cat), var(--cat-deep))"></span>
            )}
            <span
              class="absolute inset-0"
              style="background-image:linear-gradient(135deg, color-mix(in srgb, var(--cat) 38%, transparent), transparent 60%), linear-gradient(to top, rgba(9,9,10,0.82), rgba(9,9,10,0.12))"
              aria-hidden="true"
            ></span>
            <span class="relative z-10 inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-widest text-white/90">
              <span class="h-1.5 w-1.5 rounded-full bg-white/90"></span> Featured
            </span>
            <span class="relative z-10 pointer-events-none select-none font-display font-black uppercase leading-none text-white/15 text-6xl lg:text-8xl">
              {featured.data.category}
            </span>
          </div>
          <!-- CONTENT -->
          <div class="relative p-8 lg:p-10 flex flex-col justify-center">
            <span class="blog-pill self-start">{featured.data.category}</span>
            <h2 class="font-display font-black text-3xl lg:text-4xl mt-5 text-bizvault-text leading-[1.1]">
              {featured.data.title}
            </h2>
            <p class="text-bizvault-muted mt-4 leading-relaxed max-w-xl">{featured.data.description}</p>
            <p class="text-bizvault-muted text-xs mt-6 tracking-wide">
              {fmtDate(featured.data.pubDate)} · {featured.data.readTime}
            </p>
            <span class="read-link mt-6 inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase" style="color:var(--cat)">
              Read article
              <svg class="read-arrow w-4 h-4 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
            </span>
          </div>
        </a>
      )}

      <!-- MAGAZINE GRID (all posts; the featured one's card is hidden on the "All" view) -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-6" id="post-grid">
        {
          posts.map((post) => (
            <a
              href={`/insights/${post.id}`}
              data-id={post.id}
              data-category={post.data.category}
              style={vars(post.data.category)}
              class="post-card mag-card group relative flex flex-col h-full overflow-hidden rounded-lg border border-bizvault-border bg-bizvault-surface transition-[transform,border-color,opacity] duration-300"
            >
              <span class="accent-bar absolute inset-x-0 top-0 z-20 h-[3px]" aria-hidden="true" />
              <span class="mag-glow pointer-events-none absolute -top-10 -right-10 z-20 h-32 w-32 rounded-full opacity-0 transition-opacity duration-300" aria-hidden="true" />
              {post.data.cover && (
                <div class="relative aspect-[16/10] overflow-hidden">
                  <img
                    src={post.data.cover}
                    alt=""
                    width="1200"
                    height="800"
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                  <span
                    class="absolute inset-0"
                    style="background-image:linear-gradient(to top, rgba(15,15,18,0.9), transparent 72%), linear-gradient(0deg, color-mix(in srgb, var(--cat) 22%, transparent), transparent 55%)"
                    aria-hidden="true"
                  ></span>
                </div>
              )}
              <div class="relative z-10 flex flex-col flex-grow p-6">
                <span class="blog-pill self-start">{post.data.category}</span>
                <h3 class="mag-title font-display font-bold text-lg mt-4 text-bizvault-text leading-snug">
                  {post.data.title}
                </h3>
                <p class="text-bizvault-muted text-sm mt-3 line-clamp-3 flex-grow">{post.data.description}</p>
                <p class="text-bizvault-muted text-xs mt-5 tracking-wide">
                  {fmtDate(post.data.pubDate)} · {post.data.readTime}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <p id="blog-empty" class="hidden text-bizvault-muted text-sm mt-12 text-center">No articles in this category yet.</p>
    </div>
  </section>
</Layout>

<style>
  /* Category pill (palette via CSS vars set per card) */
  .blog-pill {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background-color: var(--pill-bg);
    color: var(--pill-text);
  }

  /* Magazine card accent + hover treatment */
  .mag-card .accent-bar { background-color: var(--cat); }
  .mag-card .mag-glow { background: var(--cat); filter: blur(36px); }
  .mag-card:hover { transform: translateY(-4px); border-color: var(--cat); }
  .mag-card:hover .mag-glow { opacity: 0.18; }

  /* Title underline draws left→right on hover (background-size technique) */
  .mag-title {
    background-image: linear-gradient(var(--cat), var(--cat));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 0% 2px;
    transition: background-size 0.3s ease;
    padding-bottom: 2px;
  }
  .mag-card:hover .mag-title { background-size: 100% 2px; }

  /* Featured card hover */
  .featured-card:hover { transform: translateY(-4px); border-color: var(--cat); }
  .featured-card:hover .read-arrow { transform: translateX(4px); }

  @media (prefers-reduced-motion: reduce) {
    .mag-title { transition: none; }
    .mag-card:hover, .featured-card:hover { transform: none; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-btn'));
  const featuredEl = document.getElementById('featured-card');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card'));
  const empty = document.getElementById('blog-empty');
  const section = document.getElementById('blog-main');
  const FEATURED_ID = featuredEl?.dataset.id || '';

  // A grid card is shown if: on "All" → it's not the featured duplicate; else category matches.
  const matches = (card: HTMLElement, cat: string) =>
    cat === 'All' ? card.dataset.id !== FEATURED_ID : card.dataset.category === cat;

  let current = 'All';

  // Active filter button takes its own category colour.
  const setActive = (btn: HTMLButtonElement) => {
    buttons.forEach((b) => {
      const on = b === btn;
      b.style.backgroundColor = on ? b.dataset.accent || '' : '';
      b.style.borderColor = on ? b.dataset.accent || '' : '';
      b.style.color = on ? '#09090A' : '';
    });
  };

  const applyFilter = (cat: string) => {
    current = cat;
    if (featuredEl) featuredEl.style.display = cat === 'All' ? '' : 'none';
    let shown = 0;
    cards.forEach((card) => {
      if (matches(card, cat)) {
        shown++;
        card.style.display = '';
        card.style.pointerEvents = '';
        requestAnimationFrame(() => {
          card.style.opacity = '1';
          card.style.transform = 'none';
        });
      } else {
        card.style.opacity = '0';
        card.style.transform = 'scale(0.96)';
        card.style.pointerEvents = 'none';
        window.setTimeout(() => {
          if (!matches(card, current)) card.style.display = 'none';
        }, 260);
      }
    });
    if (empty) empty.classList.toggle('hidden', shown > 0);
  };

  // Initial state: hide the featured post's duplicate grid card (it lives in the spotlight).
  cards.forEach((c) => {
    if (c.dataset.id === FEATURED_ID) c.style.display = 'none';
  });

  // Reveal: featured first, then the grid cards stagger up.
  if (!reduce && section) {
    const visible = cards.filter((c) => c.dataset.id !== FEATURED_ID);
    const initial = [featuredEl, ...visible].filter(Boolean) as HTMLElement[];
    gsap.set(initial, { opacity: 0, y: 24 });
    let done = false;
    const reveal = () => {
      if (done) return;
      done = true;
      const tl = gsap.timeline();
      if (featuredEl) tl.to(featuredEl, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out', clearProps: 'opacity,transform' });
      tl.to(visible, { opacity: 1, y: 0, duration: 0.5, stagger: 0.06, ease: 'power2.out', clearProps: 'opacity,transform' }, '-=0.25');
    };
    ScrollTrigger.create({ trigger: section, start: 'top 85%', once: true, onEnter: reveal });
    // Fire immediately if already in view on load (avoids anything stuck hidden).
    if (section.getBoundingClientRect().top < window.innerHeight * 0.95) reveal();
  }

  // Wire the filter bar.
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      setActive(btn);
      applyFilter(btn.dataset.filter || 'All');
    });
  });
  const allBtn = buttons.find((b) => b.dataset.filter === 'All');
  if (allBtn) setActive(allBtn);
</script>
