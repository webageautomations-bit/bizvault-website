---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "BizVault FZE — Dubai-based international trading and project facilitation. Procurement, logistics, and cross-border compliance for industrial and infrastructure projects worldwide." } = Astro.props;
const path = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Insights', href: '/insights' },
  { label: 'Contact', href: '/contact' },
];

const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | BizVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@600;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bizvault-bg text-bizvault-text font-sans antialiased min-h-screen">

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-bizvault-border bg-bizvault-bg/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <!-- Wordmark -->
          <a href="/" class="font-display font-extrabold tracking-tight text-xl">
            <span class="text-bizvault-amber">Biz</span><span class="text-white">Vault</span>
          </a>

          <!-- Desktop Nav -->
          <nav class="hidden lg:flex items-center gap-9">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class={`relative text-xs font-medium tracking-widest uppercase transition ${isActive(link.href) ? 'text-white' : 'text-bizvault-muted hover:text-white'}`}
              >
                {link.label}
                {isActive(link.href) && (
                  <span class="absolute -bottom-[21px] left-0 right-0 h-px bg-bizvault-amber"></span>
                )}
              </a>
            ))}
          </nav>

          <!-- Desktop CTA -->
          <a
            href="/contact"
            class="hidden lg:inline-flex items-center bg-bizvault-amber text-bizvault-bg text-xs font-semibold tracking-widest uppercase px-5 py-2.5 rounded-md hover:bg-amber-400 transition"
          >
            Submit a Trade Inquiry
          </a>

          <!-- Mobile Hamburger -->
          <button
            id="mobile-menu-btn"
            class="lg:hidden flex h-11 w-11 -mr-2.5 items-center justify-center text-bizvault-muted hover:text-white transition"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-bizvault-border bg-bizvault-bg">
        <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class={`block py-3 text-sm font-medium tracking-wide transition ${isActive(link.href) ? 'text-white' : 'text-bizvault-muted hover:text-white'}`}
            >
              {link.label}
            </a>
          ))}
          <a
            href="/contact"
            class="mt-3 inline-flex items-center justify-center bg-bizvault-amber text-bizvault-bg text-xs font-semibold tracking-widest uppercase px-5 py-3.5 rounded-md hover:bg-amber-400 transition"
          >
            Submit a Trade Inquiry
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-bizvault-border bg-bizvault-surface py-16">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">

          <!-- Col 1: Brand -->
          <div>
            <a href="/" class="font-display font-extrabold tracking-tight text-xl">
              <span class="text-bizvault-amber">Biz</span><span class="text-white">Vault</span>
            </a>
            <p class="text-sm text-bizvault-muted mt-4 max-w-xs leading-relaxed">
              Dubai-based international trading and project facilitation.
            </p>
          </div>

          <!-- Col 2: Navigate -->
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-white mb-5">Navigate</p>
            <ul class="space-y-3">
              {navLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-sm text-bizvault-muted hover:text-white transition">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Col 3: Operations -->
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-white mb-5">Operations</p>
            <ul class="space-y-3 text-sm text-bizvault-muted">
              <li><span class="text-bizvault-text">Headquarters</span> — Dubai, UAE</li>
              <li><span class="text-bizvault-text">Trade Reach</span> — Global Corridors</li>
              <li>
                <span class="text-bizvault-text">Email</span> —
                <a href="mailto:info@bizvault.ae" class="hover:text-white transition">info@bizvault.ae</a>
              </li>
            </ul>
          </div>

          <!-- Col 4: Engage -->
          <div>
            <p class="text-xs font-semibold tracking-widest uppercase text-white mb-5">Engage</p>
            <ul class="space-y-3">
              <li>
                <a href="/contact" class="text-sm text-bizvault-muted hover:text-white transition">Submit a Trade Inquiry</a>
              </li>
              <li>
                <a href="https://wa.me/923338833377?text=Hi%2C%20I%27m%20interested%20in%20a%20trade%20inquiry%20with%20BizVault.%20Please%20guide%20me%20with%20the%20process." target="_blank" rel="noopener" class="text-sm text-bizvault-muted hover:text-white transition">WhatsApp</a>
              </li>
            </ul>
          </div>

        </div>

        <!-- Bottom bar -->
        <div class="mt-14 pt-8 border-t border-bizvault-border">
          <p class="text-bizvault-muted text-xs text-center tracking-wide">
            &copy; Copyright 2026. BizVault. All Rights Reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const isHidden = menu?.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(!isHidden));
      });
    </script>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';

      gsap.registerPlugin(ScrollTrigger);

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduceMotion) {
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        (window as any).lenis = lenis;
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => { lenis.raf(time * 1000); });
        gsap.ticker.lagSmoothing(0);
      }

      /* ---- Global scroll-reveal mechanism ----
         Any element with [data-reveal] fades + slides up once when it enters the
         viewport. Optional [data-reveal-delay] (seconds) fine-tunes per-element timing;
         otherwise elements entering together stagger 0.08s apart. */
      const revealEls = gsap.utils.toArray<HTMLElement>('[data-reveal]');
      if (revealEls.length) {
        if (reduceMotion) {
          // Never leave content hidden: show everything immediately, no animation.
          gsap.set(revealEls, { opacity: 1, y: 0, clearProps: 'opacity,transform' });
        } else {
          gsap.set(revealEls, { opacity: 0, y: 30 });
          ScrollTrigger.batch('[data-reveal]', {
            start: 'top 85%',
            once: true,
            onEnter: (batch) => {
              batch.forEach((el, i) => {
                const attr = el.getAttribute('data-reveal-delay');
                const delay = attr !== null ? parseFloat(attr) : i * 0.08;
                gsap.to(el, { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out', delay });
              });
            },
          });
        }
      }
    </script>

  </body>
</html>
