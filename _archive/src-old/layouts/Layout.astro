---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "BizVault FZE — Dubai's structured trade facilitation company. Complex procurement, international logistics, cross-border compliance." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | BizVault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-[#0a0a0a] text-white min-h-screen" style="font-family: 'Inter', system-ui, sans-serif;">

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/60 bg-[#0a0a0a]/95 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <!-- Logo -->
          <a href="/" class="text-lg font-bold tracking-widest text-white hover:text-zinc-300 transition-colors uppercase">
            BizVault
          </a>

          <!-- Desktop Nav Links -->
          <div class="hidden md:flex items-center gap-10">
            <a
              href="/"
              class={`text-sm tracking-wide font-medium transition-colors ${currentPath === '/' ? 'text-white' : 'text-zinc-500 hover:text-white'}`}
            >
              Home
            </a>
            <a
              href="/portfolio"
              class={`text-sm tracking-wide font-medium transition-colors ${currentPath === '/portfolio' ? 'text-white' : 'text-zinc-500 hover:text-white'}`}
            >
              Portfolio
            </a>
            <a
              href="/contact"
              class={`text-sm tracking-wide font-medium transition-colors ${currentPath === '/contact' ? 'text-white' : 'text-zinc-500 hover:text-white'}`}
            >
              Contact
            </a>
          </div>

          <!-- Desktop CTA -->
          <a
            href="/contact"
            class="hidden md:inline-flex items-center px-5 py-2.5 text-xs font-semibold tracking-widest uppercase text-black bg-white hover:bg-zinc-200 transition-colors"
          >
            Submit a Trade Inquiry
          </a>

          <!-- Mobile Hamburger -->
          <button id="mobile-menu-btn" class="md:hidden text-zinc-400 hover:text-white transition-colors" aria-label="Open menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>

        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-zinc-800">
        <div class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-5">
          <a href="/" class="text-sm text-zinc-400 hover:text-white transition-colors tracking-wide">Home</a>
          <a href="/portfolio" class="text-sm text-zinc-400 hover:text-white transition-colors tracking-wide">Portfolio</a>
          <a href="/contact" class="text-sm text-zinc-400 hover:text-white transition-colors tracking-wide">Contact</a>
          <a
            href="/contact"
            class="mt-2 inline-flex items-center justify-center px-5 py-3 text-xs font-semibold tracking-widest uppercase text-black bg-white hover:bg-zinc-200 transition-colors"
          >
            Submit a Trade Inquiry
          </a>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-16">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/60 bg-[#0a0a0a]">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-14">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
          <div>
            <p class="text-lg font-bold tracking-widest uppercase text-white">BizVault</p>
            <p class="text-sm text-zinc-600 mt-2">BizVault FZE — Dubai, United Arab Emirates</p>
          </div>
          <div class="flex items-center gap-8">
            <a href="/" class="text-sm text-zinc-500 hover:text-white transition-colors">Home</a>
            <a href="/portfolio" class="text-sm text-zinc-500 hover:text-white transition-colors">Portfolio</a>
            <a href="/contact" class="text-sm text-zinc-500 hover:text-white transition-colors">Contact</a>
          </div>
        </div>
        <div class="mt-10 pt-8 border-t border-zinc-900">
          <p class="text-xs text-zinc-700 text-center tracking-wide">
            &copy; Copyright 2026. BizVault. All Rights Reserved.
          </p>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>

  </body>
</html>
