---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Submit a trade inquiry to BizVault FZE. Dubai-based structured trade facilitation for complex, large-scale procurement.">

  <!-- ─── CONTACT SECTION ──────────────────────────────────────────────────── -->
  <section class="min-h-screen py-24 lg:py-36">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">

        <!-- Left: Header + Info -->
        <div>
          <p class="text-xs font-semibold tracking-[0.3em] text-zinc-500 uppercase mb-8">
            Get in Touch
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight uppercase text-white mb-8">
            Submit a Trade Inquiry
          </h1>
          <p class="text-sm text-zinc-500 leading-relaxed mb-12 max-w-md">
            Complete the form and a member of the BizVault team will review your requirements and respond with a structured assessment. All inquiries are treated with confidentiality.
          </p>

          <!-- Divider -->
          <div class="border-t border-zinc-800 pt-10 flex flex-col gap-6">
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-zinc-600 mb-1">Location</p>
              <p class="text-sm text-zinc-400">Dubai, United Arab Emirates</p>
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-zinc-600 mb-1">Entity</p>
              <p class="text-sm text-zinc-400">BizVault FZE</p>
            </div>
            <div>
              <p class="text-xs font-semibold tracking-widest uppercase text-zinc-600 mb-2">WhatsApp</p>
              <a
                href="https://wa.me/923338833377"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 px-5 py-3 border border-zinc-700 text-sm font-medium text-white hover:border-white hover:bg-zinc-900 transition-colors"
              >
                <svg class="w-4 h-4 text-zinc-400" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Message on WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div>
          <form
            method="POST"
            class="flex flex-col gap-6"
            id="trade-inquiry-form"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <!-- First Name -->
              <div class="flex flex-col gap-2">
                <label for="first-name" class="text-xs font-semibold tracking-widest uppercase text-zinc-500">
                  First Name
                </label>
                <input
                  type="text"
                  id="first-name"
                  name="first_name"
                  required
                  placeholder="John"
                  class="w-full bg-transparent border border-zinc-800 text-white text-sm px-4 py-3.5 placeholder:text-zinc-700 focus:outline-none focus:border-zinc-500 transition-colors"
                />
              </div>

              <!-- Last Name -->
              <div class="flex flex-col gap-2">
                <label for="last-name" class="text-xs font-semibold tracking-widest uppercase text-zinc-500">
                  Last Name
                </label>
                <input
                  type="text"
                  id="last-name"
                  name="last_name"
                  required
                  placeholder="Smith"
                  class="w-full bg-transparent border border-zinc-800 text-white text-sm px-4 py-3.5 placeholder:text-zinc-700 focus:outline-none focus:border-zinc-500 transition-colors"
                />
              </div>
            </div>

            <!-- Phone -->
            <div class="flex flex-col gap-2">
              <label for="phone" class="text-xs font-semibold tracking-widest uppercase text-zinc-500">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+971 50 000 0000"
                class="w-full bg-transparent border border-zinc-800 text-white text-sm px-4 py-3.5 placeholder:text-zinc-700 focus:outline-none focus:border-zinc-500 transition-colors"
              />
            </div>

            <!-- Organization -->
            <div class="flex flex-col gap-2">
              <label for="organization" class="text-xs font-semibold tracking-widest uppercase text-zinc-500">
                Organization
              </label>
              <input
                type="text"
                id="organization"
                name="organization"
                required
                placeholder="Company Name"
                class="w-full bg-transparent border border-zinc-800 text-white text-sm px-4 py-3.5 placeholder:text-zinc-700 focus:outline-none focus:border-zinc-500 transition-colors"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label for="email" class="text-xs font-semibold tracking-widest uppercase text-zinc-500">
                Email Address
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                class="w-full bg-transparent border border-zinc-800 text-white text-sm px-4 py-3.5 placeholder:text-zinc-700 focus:outline-none focus:border-zinc-500 transition-colors"
              />
            </div>

            <!-- Submit -->
            <div class="pt-2">
              <button
                type="submit"
                class="w-full sm:w-auto px-10 py-4 text-xs font-semibold tracking-widest uppercase text-black bg-white hover:bg-zinc-200 active:bg-zinc-300 transition-colors cursor-pointer"
              >
                Submit Inquiry
              </button>
            </div>

            <p class="text-xs text-zinc-700 leading-relaxed">
              By submitting this form, you consent to BizVault contacting you regarding your trade inquiry. All information is treated with strict confidentiality.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── WHATSAPP BANNER ──────────────────────────────────────────────────── -->
  <section class="border-t border-zinc-800/60 py-16 bg-[#0d0d0d]">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h2 class="text-xl font-black text-white uppercase tracking-tight mb-2">Prefer to Talk Directly?</h2>
          <p class="text-sm text-zinc-500">Reach our team on WhatsApp for faster response on urgent trade requirements.</p>
        </div>
        <a
          href="https://wa.me/923338833377"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center gap-3 px-7 py-3.5 text-xs font-semibold tracking-widest uppercase text-black bg-white hover:bg-zinc-200 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Open WhatsApp
        </a>
      </div>
    </div>
  </section>

</Layout>
